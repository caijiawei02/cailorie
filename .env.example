# Telegram bot token from @BotFather
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE

# Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of group chat IDs the bot is allowed to operate in.
# Use the /chatid command (DM the bot, or send it in the group) to discover IDs.
GROUP_CHAT_ID=YOUR_GROUP_CHAT_ID_HERE

# Timezone for day boundaries and the 23:58 daily summary (IANA name).
TZ=Asia/Singapore

# Path to the SQLite database file. On Oracle VM, use a persistent path.
DB_PATH=/var/lib/cailorie/data.db