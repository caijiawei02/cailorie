# Telegram bot token from @BotFather
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE

# Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of group chat IDs the bot is allowed to operate in.
# Use the /chatid command (DM the bot, or send it in the group) to discover IDs.
GROUP_CHAT_ID=YOUR_GROUP_CHAT_ID_HERE

# Timezone for day boundaries and the 23:58 daily summary (IANA name).
TZ=Asia/Singapore

# Path to the SQLite database file. On Oracle VM, use a persistent path.
DB_PATH=/var/lib/cailorie/data.db

# ── Webhook config (required) ──
# The public HTTPS URL Telegram will POST updates to. Must match the nginx
# location block. Include a secret path segment for security, e.g.
#   https://your-domain.example.com/tg/your-secret-path/
WEBHOOK_PUBLIC_URL=https://your-domain.example.com/tg/your-secret-path/

# Address the bot's webhook HTTP listener binds to (inside the container).
WEBHOOK_LISTEN=:8080

# Secret token Telegram sends in the X-Telegram-Bot-Api-Secret-Token header.
# Generate a random string (e.g. openssl rand -hex 32). Telegram requires this
# to be 1-256 chars of A-Za-z0-9_-. Set the same value in the nginx
# forwarding — nginx passes the header through unchanged.
WEBHOOK_SECRET_TOKEN=change_me_to_a_random_string

# Address of the separate /health endpoint (for Docker/nginx healthchecks).
HEALTH_LISTEN=:8081